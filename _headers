# Security headers (apply to all paths)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Short cache for main HTML (news site needs fresh content)
# JS is inlined in index.html, so same rule
/index.html
  Cache-Control: public, max-age=120, stale-while-revalidate=3600

# Long cache for assets (if any non-HTML files are added later)
/*
  Cache-Control: public, max-age=31536000, immutable